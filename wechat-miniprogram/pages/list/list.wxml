<view class="container">
  <!-- 标题 -->
  <view class="card" style="padding: 30rpx;">
    <view style="font-size: 36rpx; font-weight: bold;">所有周刊</view>
    <view style="font-size: 26rpx; color: #6b7280; margin-top: 8rpx;">
      共 {{issues.length}} 期内容
    </view>
  </view>

  <!-- 周刊列表 -->
  <view 
    wx:for="{{issues}}" 
    wx:key="slug"
    class="card"
    bindtap="goToDetail"
    data-slug="{{item.slug}}"
  >
    <view style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16rpx;">
      <view style="font-size: 24rpx; color: #9ca3af;">
        {{item.date}}
      </view>
      <view style="font-size: 22rpx; color: #0ea5e9; background: #e0f2fe; padding: 4rpx 16rpx; border-radius: 8rpx;">
        第{{item.issue}}期
      </view>
    </view>
    
    <view style="font-size: 32rpx; font-weight: 600; margin-bottom: 12rpx; line-height: 1.4;">
      {{item.title}}
    </view>
    
    <view style="font-size: 28rpx; color: #6b7280; line-height: 1.6;">
      {{item.description}}
    </view>
    
    <view style="margin-top: 20rpx; text-align: right;">
      <text style="font-size: 26rpx; color: #0ea5e9;">阅读全文 →</text>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{!loading && issues.length === 0}}" class="empty">
    <image class="empty-icon" src="/images/empty.png" mode="aspectFit"/>
    <text>暂无周刊内容</text>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading">
    <text style="color: #6b7280;">加载中...</text>
  </view>

  <!-- 底部提示 -->
  <view wx:if="{{!loading && !hasMore && issues.length > 0}}" style="text-align: center; padding: 40rpx; color: #9ca3af; font-size: 26rpx;">
    已经到底了
  </view>
</view>
