/**app.wxss**/
page {
  --primary: #0ea5e9;
  --primary-light: #e0f2fe;
  --text-primary: #1f2937;
  --text-secondary: #6b7280;
  --background: #f3f4f6;
  --white: #ffffff;
  --border: #e5e7eb;
  
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  background-color: var(--background);
  color: var(--text-primary);
  line-height: 1.6;
}

.container {
  padding: 20rpx;
}

.card {
  background: var(--white);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: var(--text-primary);
}

.card-content {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

.tag {
  display: inline-block;
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.tag-primary {
  background: var(--primary-light);
  color: var(--primary);
}

.tag-default {
  background: var(--background);
  color: var(--text-secondary);
}

.button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 40rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: opacity 0.2s;
}

.button-primary {
  background: var(--primary);
  color: var(--white);
}

.button:active {
  opacity: 0.8;
}

.text-center {
  text-align: center;
}

.mt-20 {
  margin-top: 40rpx;
}

.mb-20 {
  margin-bottom: 40rpx;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
}

.empty {
  text-align: center;
  padding: 80rpx 40rpx;
  color: var(--text-secondary);
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.3;
}
